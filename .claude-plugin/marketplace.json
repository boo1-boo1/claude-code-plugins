{
  "name": "python-tooling-plugins",
  "owner": {
    "name": "boo1-boo1",
    "email": "38583719+boo1-boo1@users.noreply.github.com"
  },
  "metadata": {
    "description": "Marketplace of Claude Code plugins.",
    "version": "0.1.0"
  },
  "plugins": [
    {
      "name": "basedpyright-lsp",
      "description": "Python language server (basedpyright) for type checking and code intelligence",
      "version": "1.0.0",
      "author": {
        "name": "boo1-boo1",
        "email": "38583719+boo1-boo1@users.noreply.github.com"
      },
      "source": "./plugins/basedpyright-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "basedpyright": {
          "command": "basedpyright-langserver",
          "args": [
            "--stdio"
          ],
          "extensionToLanguage": {
            ".py": "python",
            ".pyi": "python"
          }
        }
      }
    },
    {
      "name": "black-formatter",
      "source": "./plugins/black-formatter",
      "description": "Python code formatting with Black - the uncompromising code formatter",
      "version": "1.0.0",
      "category": "development"
    },
    {
      "name": "ruff-linter",
      "source": "./plugins/ruff-linter",
      "description": "Python linting and code quality checks with Ruff - an extremely fast Python linter",
      "version": "1.0.0",
      "category": "development",
      "lspServers": {
        "ruff": {
          "command": "ruff",
          "args": [
            "server"
          ],
          "extensionToLanguage": {
            ".py": "python",
            ".pyi": "python"
          }
        }
      }
    }
  ]
}
