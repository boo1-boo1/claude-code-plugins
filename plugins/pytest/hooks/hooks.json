{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/scripts/run-tests.sh",
            "timeout": 120,
            "statusMessage": "Running pytest..."
          }
        ]
      }
    ]
  }
}
