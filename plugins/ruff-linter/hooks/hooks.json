{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/scripts/fix-lint.sh",
            "timeout": 30,
            "statusMessage": "Running ruff --fix..."
          }
        ]
      }
    ]
  }
}
